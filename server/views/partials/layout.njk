{% extends "govuk/template.njk" %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
{% endblock %}

{% block pageTitle %}{{pageTitle | default(applicationName)}}{% endblock %}

{% block header %}
  {% include "./prob_fe_header.njk" %}
  {% block banner %}{% endblock %}
{% endblock %}

{% block bodyStart %}
{% endblock %}

{% block footer %}
  {% include "./prob_fe_footer.njk" %}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
  <script nonce="{{ cspNonce }}">
    window.csrfToken = "{{ csrfToken }}";
  </script>
  <script nonce="{{ cspNonce }}">
    document.addEventListener('DOMContentLoaded', function () {
      document.initialiseTelemetry('{{ applicationInsightsConnectionString | default(' ') }}', '{{ applicationInsightsRoleName }}', '{{ user.username }}')
    })
  </script>
{% endblock %}
